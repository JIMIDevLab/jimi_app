# Copy to `.env` next to docker-compose.yml.
#
# This stack only runs the web frontend. The API is deployed
# independently from `../jimi_api`.

# ---- Web app build arg -------------------------------------------------------
# Baked into the static JS bundle at `docker compose build app`. Must be the
# public URL of the API as seen by the browser (and by the Android app).
EXPO_PUBLIC_API_URL=https://jimi-api.julsql.fr

# ---- Local port --------------------------------------------------------------
# Bound to 127.0.0.1 only — never public. The host nginx vhost in
# infra/nginx/jimi.julsql.fr.conf reverse-proxies onto this.
APP_PORT=8101
